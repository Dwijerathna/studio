# Public site URL — required in production (sitemap, canonical, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Plausible analytics domain (defaults to host from SITE_URL).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Contact form (Formspree).
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Optional contact overrides.
NEXT_PUBLIC_CONTACT_PHONE=+94 0778264843
NEXT_PUBLIC_CONTACT_GITHUB=https://github.com/Dwijerathna
NEXT_PUBLIC_CONTACT_LINKEDIN=https://www.linkedin.com/in/your-profile
